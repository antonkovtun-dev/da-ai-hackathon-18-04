# Copy to .env for local overrides (never commit .env)
# These are insecure dev defaults — change DB_USER and DB_PASSWORD before any deployment.

# PostgreSQL connection — used by both the postgres and backend containers
DB_USER=chat
DB_PASSWORD=chat

# Backend — inside Docker Compose, DB_URL is automatically set to jdbc:postgresql://postgres:5432/chat
# (using the postgres service name). Override here only when running the backend directly on the host outside Docker.
DB_URL=jdbc:postgresql://localhost:5432/chat

# File upload storage directory (must be writable by the backend process)
# In Docker Compose this is mapped to the uploads_data named volume.
# When running the backend directly on the host (outside Docker), set this to a local path like ./uploads
# and create the directory manually before starting the backend.
UPLOAD_DIR=/data/uploads
